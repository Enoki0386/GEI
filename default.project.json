{
  "name": "GEI",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "GameData": {
        "$path": "src/ReplicatedStorage/GameData.luau"
      },
      "Remotes": {
        "$path": "src/ReplicatedStorage/Remotes",
        "$ignoreUnknownInstances": true
      },
      "Shared": {
        "$path": "src/ReplicatedStorage/Shared"
      },
      "Tools": {
        "$path": "src/ReplicatedStorage/Tools",
        "$ignoreUnknownInstances": true
      },
      "ToolModels": {
        "$path": "src/ReplicatedStorage/ToolModels",
        "$ignoreUnknownInstances": true
      },
      "WasteModels": {
        "$path": "src/ReplicatedStorage/WasteModels",
        "$ignoreUnknownInstances": true
      },
      "Sounds": {
        "$path": "src/ReplicatedStorage/Sounds",
        "$ignoreUnknownInstances": true
      }
    },

    "ReplicatedFirst": {
      "$className": "ReplicatedFirst",
      "$path": "src/ReplicatedFirst"
    },

    "ServerScriptService": {
      "$className": "ServerScriptService",
      "Core": {
        "$path": "src/ServerScriptService/Core"
      },
      "Systems": {
        "$path": "src/ServerScriptService/Systems"
      }
    },

    "StarterGui": {
      "$path": "src/StarterGui"
    },

    "StarterPlayer": {
      "$className": "StarterPlayer",
      "$properties": {
        "EnableMouseLockOption": true
      },
      "StarterPlayerScripts": {
        "$path": "src/StarterPlayer/StarterPlayerScripts"
      }
    },

    "Workspace": {
      "$className": "Workspace",
      "$ignoreUnknownInstances": true
    }
  }
}

{
  "name": "GEI",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "$path": "src/ReplicatedStorage"
    },

    "ServerScriptService": {
      "$path": "src/ServerScriptService"
    },

    "StarterGui": {
      "MainHUD": {
        "$className": "ScreenGui",
        "$path": "src/StarterGui/MainHUD",
        "$properties": {
          "DisplayOrder": 10,
          "IgnoreGuiInset": false,
          "ResetOnSpawn": false,
          "ZIndexBehavior": "Sibling"
        }
      }
    },

    "StarterPlayer": {
      "$properties": {
        "EnableMouseLockOption": true
      },
      "StarterPlayerScripts": {
        "$path": "src/StarterPlayer/StarterPlayerScripts"
      }
    },

    "Workspace": {
      "$path": "src/Workspace",
      "$properties": {
        "FilteringEnabled": true
      }
    },

    "Lighting": {
      "$properties": {
        "Ambient": [
          0.05,
          0.05,
          0.05
        ],
        "Brightness": 2,
        "GlobalShadows": true,
        "Technology": "Voxel"
      }
    },

    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}

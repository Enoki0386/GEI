{
  "name": "GEI",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "$path": "src/ReplicatedStorage"
    },

    "ServerScriptService": {
      "$className": "ServerScriptService",
      "Core": {
        "$path": "src/ServerScriptService/Core"
      },
      "Systems": {
        "$path": "src/ServerScriptService/Systems"
      }
    },

    "StarterGui": {
      "$path": "src/StarterGui"
    },

    "StarterPlayer": {
      "$className": "StarterPlayer",
      "$properties": {
        "EnableMouseLockOption": true
      },
      "StarterPlayerScripts": {
        "$path": "src/StarterPlayer/StarterPlayerScripts"
      }
    },

    "Workspace": {
      "$className": "Workspace",
      "$ignoreUnknownInstances": true
    }
  }
}
